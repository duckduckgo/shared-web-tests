# Nintendo Store Test Credentials
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control

# Nintendo Account credentials (required for digital game purchases)
NINTENDO_EMAIL=your-email@example.com
NINTENDO_PASSWORD=your-password

# Optional: Skip login if you want to test guest flow only
# NINTENDO_SKIP_LOGIN=true

# Subscription Flow Test (dev box)
# Used by: npm run test:subscription-flow
DEV_BOX_URL=https://euw-serp-dev-testing16.duckduckgo.com
DEV_BOX_USERNAME=
DEV_BOX_PASSWORD=
# Override fake payment page URL (default: https://www.payment-company.site)
# PAYMENT_PAGE_URL=https://www.payment-company.site
